<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/payment_background">

    <!-- Цена -->
    <TextView
        android:id="@+id/priceTop"
        android:text="0 ₽"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_margin="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Кнопка отмены -->
    <ImageButton
        android:id="@+id/cancelButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="@android:color/transparent"
        app:tint="#FFFFFF"/>

    <!-- Таймер -->
    <TextView
        android:id="@+id/timerText"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_below="@id/priceTop"
        android:layout_marginStart="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Иконка NFC с анимацией -->
    <ImageView
        android:id="@+id/nfcIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        android:src="@drawable/nfc_pulse_animation"/>

    <!-- Текст NFC -->
    <TextView
        android:id="@+id/nfcText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Приложите карту"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:layout_below="@id/nfcIcon"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"/>

    <!-- Кнопка FacePay -->
    <Button
        android:id="@+id/faceButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="20dp"
        android:backgroundTint="#00E5FF"
        android:text="Оплата по лицу"
        android:textColor="#000000"/>

    <!-- Flash при оплате -->
    <View
        android:id="@+id/successFlash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:alpha="0"
        android:visibility="gone"/>

    <!-- Сумма/статус после оплаты -->
    <TextView
        android:id="@+id/successAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"/>

</RelativeLayout>
